@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(HDF5 REQUIRED COMPONENTS C)
if(@CELLSHARD_ENABLE_CUDA@)
    find_dependency(CUDAToolkit REQUIRED)
endif()

if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/CellShardTargets.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/CellShardTargets.cmake")
endif()

set(CellShard_KNOWN_COMPONENTS
    headers
    inspect
    runtime
    export
    h5ad_python
)
set(CellShard_AVAILABLE_COMPONENTS @CELLSHARD_PACKAGE_COMPONENTS@)

foreach(_cellshard_component IN LISTS CellShard_KNOWN_COMPONENTS)
    set(CellShard_${_cellshard_component}_FOUND FALSE)
endforeach()

foreach(_cellshard_component IN LISTS CellShard_AVAILABLE_COMPONENTS)
    if(TARGET CellShard::${_cellshard_component})
        set(CellShard_${_cellshard_component}_FOUND TRUE)
    endif()
endforeach()

set(CellShard_MISSING_COMPONENTS "")
foreach(_cellshard_component IN LISTS CellShard_FIND_COMPONENTS)
    if(NOT _cellshard_component IN_LIST CellShard_KNOWN_COMPONENTS)
        set(CellShard_FOUND FALSE)
        set(CellShard_NOT_FOUND_MESSAGE
            "Unknown CellShard component: ${_cellshard_component}. "
            "Known components: ${CellShard_KNOWN_COMPONENTS}"
        )
        break()
    endif()

    if(NOT CellShard_${_cellshard_component}_FOUND)
        list(APPEND CellShard_MISSING_COMPONENTS ${_cellshard_component})
    endif()
endforeach()

if(CellShard_MISSING_COMPONENTS)
    list(JOIN CellShard_MISSING_COMPONENTS ", " _cellshard_missing_components)
    list(JOIN CellShard_AVAILABLE_COMPONENTS ", " _cellshard_available_components)
    set(CellShard_FOUND FALSE)
    set(CellShard_NOT_FOUND_MESSAGE
        "Requested CellShard components are unavailable in this install: "
        "${_cellshard_missing_components}. "
        "Available components: ${_cellshard_available_components}"
    )
endif()

check_required_components(CellShard)
